{
	"name": "pi-chat",
	"version": "0.1.0",
	"private": false,
	"description": "Multi-service chat bridge extension for pi",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"chat",
		"bridge",
		"telegram",
		"discord",
		"extension"
	],
	"license": "Apache-2.0",
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"dependencies": {
		"@earendil-works/gondolin": "^0.7.0",
		"discord.js": "^14.26.3",
		"remend": "^1.3.0",
		"undici": "^7.28.0",
		"ws": "^8.18.3"
	},
	"scripts": {
		"check": "biome check . && tsc --noEmit",
		"format": "biome check --write .",
		"telegram-broker": "tsx src/telegram-broker.ts",
		"test": "tsx --test test/*.test.ts"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.5",
		"@types/node": "^24.5.2",
		"@types/ws": "^8.18.1",
		"tsx": "^4.23.1",
		"typescript": "^5.9.2"
	}
}
